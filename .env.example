# Stellar Charity Tracker - Environment Variables Template
# Copy this to frontend/.env.local or frontend/.env

# The contract ID of your deployed soroban contract on Testnet
NEXT_PUBLIC_CONTRACT_ID=

# Network Settings (Stellar Testnet - DO NOT CHANGE FOR TESTNET TESTING)
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
